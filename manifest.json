{
  "name": "Omnira",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": { "16": "icons/logo_16x16.png",
          "32": "icons/logo_32x32.png",
          "48": "icons/logo_48x48.png",
          "128": "icons/logo_128x128.png" },
  "content_scripts":[
    {
      "matches":["https://www.youtube.com/*"],
      "js":["ytHandle.js"]
    }
  ]
}